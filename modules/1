$sub   = $_GET['sub']   ?? 'dashboard';
$action= $_GET['action'] ?? 'list';
$msg   = '';

// ── POST handlers ──────────────────────────────────────────────
if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    $pa = $_POST['action'] ?? '';

    // Guardar animal
    if ($pa === 'save_animal') {
        $id = (int)($_POST['id'] ?? 0);
        $fields = ['codigo_interno','numero_arete','rfid','nombre','sexo','raza','color',
                   'fecha_nacimiento','tipo','estado','estado_reproductivo','fundo_id','potrero_id',
                   'lote_id','peso_inicial','peso_actual','origen','fecha_ingreso',
                   'produccion_estimada','notas'];
        $data = []; foreach ($fields as $f) $data[$f] = trim($_POST[$f] ?? '') ?: null;
        // Foto
        $foto_nueva = null;
        if (!empty($_FILES['foto']['tmp_name']) && $_FILES['foto']['error'] === 0) {
            $dir = UPLOADS_PATH . '/ganado/';
            if (!is_dir($dir)) mkdir($dir, 0755, true);
            $ext = pathinfo($_FILES['foto']['name'], PATHINFO_EXTENSION);
            $fname = 'animal_'.($id?:time()).'_'.uniqid().'.'.$ext;
            if (move_uploaded_file($_FILES['foto']['tmp_name'], $dir.$fname))
                $foto_nueva = 'ganado/'.$fname;
        }
        if ($id) {
            $sets = implode(',', array_map(fn($f)=>"$f=:$f", $fields));
            if ($foto_nueva) { $sets .= ',foto=:foto'; $data['foto'] = $foto_nueva; }
            $db->prepare("UPDATE gv_animales SET $sets WHERE id=:id")->execute(array_merge($data,['id'=>$id]));
        } else {
            if ($foto_nueva) { $fields[] = 'foto'; $data['foto'] = $foto_nueva; }
            $cols = implode(',', $fields); $pls = implode(',', array_map(fn($f)=>":$f", $fields));
            $db->prepare("INSERT INTO gv_animales ($cols) VALUES ($pls)")->execute($data);
        }
        $msg = 'ok'; $action = 'list';
    }

    // Guardar celo
    if ($pa === 'save_celo') {
        $fields = ['animal_id','fecha','hora','metodo_deteccion','comportamiento','temperatura','observaciones','veterinario_id'];
        $data = []; foreach ($fields as $f) $data[$f] = trim($_POST[$f] ?? '') ?: null;
        $data['inflamacion'] = isset($_POST['inflamacion']) ? 1 : 0;
        $data['programar_inseminacion'] = isset($_POST['programar_inseminacion']) ? 1 : 0;
        $cols = implode(',', array_merge($fields,['inflamacion','programar_inseminacion']));
        $pls  = implode(',', array_map(fn($f)=>":$f", array_merge($fields,['inflamacion','programar_inseminacion'])));
        $db->prepare("INSERT INTO gv_celos ($cols) VALUES ($pls)")->execute($data);
        $msg = 'ok'; $sub = 'reproduccion'; $action = 'list';
    }

    // Guardar inseminación
    if ($pa === 'save_insem') {
        $fields = ['animal_id','fecha','hora','tecnico_id','toro_id','codigo_pajilla',
                   'raza_genetica','procedencia_semen','observaciones','fecha_diagnostico_prenez','notas'];
        $data = []; foreach ($fields as $f) $data[$f] = trim($_POST[$f] ?? '') ?: null;
        $cols = implode(',', $fields); $pls = implode(',', array_map(fn($f)=>":$f", $fields));
        $db->prepare("INSERT INTO gv_inseminaciones ($cols) VALUES ($pls)")->execute($data);
        // Actualizar stock pajilla
        if ($data['codigo_pajilla']) {
            $db->prepare("UPDATE gv_banco_semen SET cantidad_usada=cantidad_usada+1 WHERE codigo_pajilla=? AND activo=1")
               ->execute([$data['codigo_pajilla']]);
        }
        $msg = 'ok'; $sub = 'reproduccion'; $action = 'list';
    }

    // Guardar diagnóstico preñez
    if ($pa === 'save_prenez') {
        $id_ins = (int)($_POST['inseminacion_id'] ?? 0);
        $res    = $_POST['resultado'] ?? 'vacia';
        $animal_id = (int)$_POST['animal_id'];
        $fecha_ins = trim($_POST['fecha_inseminacion'] ?? '');
        $fpp = null;
        if ($res === 'prenada' && $fecha_ins) {
            $fpp = date('Y-m-d', strtotime($fecha_ins . ' +283 days')); // gestación bovina ~283 días
        }
        $db->prepare("INSERT INTO gv_prenez (animal_id,inseminacion_id,fecha_diagnostico,resultado,fecha_inseminacion,veterinario_id,metodo,fecha_probable_parto,observaciones) VALUES (?,?,?,?,?,?,?,?,?)")
           ->execute([$animal_id,$id_ins,$_POST['fecha_diagnostico'],$res,$fecha_ins,$_POST['veterinario_id']??null,$_POST['metodo']??'ecografia',$fpp,$_POST['observaciones']??'']);
        if ($res === 'prenada') {
            $db->prepare("UPDATE gv_animales SET estado_reproductivo='prenada' WHERE id=?")->execute([$animal_id]);
        }
        if ($id_ins) {
            $db->prepare("UPDATE gv_inseminaciones SET resultado=? WHERE id=?")->execute([$res,$id_ins]);
        }
        $msg = 'ok'; $sub = 'reproduccion'; $action = 'list';
    }

    // Guardar parto
    if ($pa === 'save_parto') {
        $madre_id = (int)$_POST['madre_id'];
        $fields   = ['madre_id','prenez_id','fecha_parto','hora_parto','tipo','cria_sexo',
                     'cria_peso','cria_estado','cria_arete','veterinario_id'];
        $data = []; foreach ($fields as $f) $data[$f] = trim($_POST[$f] ?? '') ?: null;
        $data['complicaciones'] = trim($_POST['complicaciones'] ?? '') ?: null;
        $data['observaciones']  = trim($_POST['observaciones']  ?? '') ?: null;
        $cols = implode(',', array_merge($fields,['complicaciones','observaciones']));
        $pls  = implode(',', array_map(fn($f)=>":$f", array_merge($fields,['complicaciones','observaciones'])));
        $db->prepare("INSERT INTO gv_partos ($cols) VALUES ($pls)")->execute($data);
        $db->prepare("UPDATE gv_animales SET estado_reproductivo='lactante' WHERE id=?")->execute([$madre_id]);
        $msg = 'ok'; $sub = 'reproduccion'; $action = 'list';
    }

    // Guardar producción leche
    if ($pa === 'save_leche') {
        $db->prepare("INSERT INTO gv_leche (animal_id,lote_id,fecha,turno,litros,calidad,observaciones,registrado_por) VALUES (?,?,?,?,?,?,?,?)")
           ->execute([(int)$_POST['animal_id'],$_POST['lote_id']??null,$_POST['fecha'],$_POST['turno'],$_POST['litros'],$_POST['calidad']??'A',$_POST['observaciones']??'',$user['id']]);
        $msg = 'ok'; $sub = 'leche'; $action = 'list';
    }

    // Guardar peso
    if ($pa === 'save_peso') {
        $animal_id = (int)$_POST['animal_id'];
        $peso_nuevo = (float)$_POST['peso'];
        $st = $db->prepare("SELECT peso_actual FROM gv_animales WHERE id=?"); $st->execute([$animal_id]); $row = $st->fetch();
        $peso_ant = $row['peso_actual'] ?? null;
        // Ganancia diaria vs última pesada
        $gan = null;
        if ($peso_ant) {
            $ult = $db->prepare("SELECT fecha FROM gv_pesos WHERE animal_id=? ORDER BY fecha DESC LIMIT 1"); $ult->execute([$animal_id]); $ult = $ult->fetch();
            if ($ult) {
                $dias = max(1, (int)round((strtotime($_POST['fecha'])-strtotime($ult['fecha']))/86400));
                $gan  = round(($peso_nuevo - $peso_ant) / $dias, 3);
            }
        }
        $db->prepare("INSERT INTO gv_pesos (animal_id,fecha,peso,peso_anterior,ganancia_diaria,condicion_corporal,observaciones,registrado_por) VALUES (?,?,?,?,?,?,?,?)")
           ->execute([$animal_id,$_POST['fecha'],$peso_nuevo,$peso_ant,$gan,$_POST['condicion_corporal']??null,$_POST['observaciones']??'',$user['id']]);
        $db->prepare("UPDATE gv_animales SET peso_actual=? WHERE id=?")->execute([$peso_nuevo,$animal_id]);
        $msg = 'ok'; $sub = 'peso'; $action = 'list';
    }

    // Guardar fundo
    if ($pa === 'save_fundo') {
        $id = (int)($_POST['id'] ?? 0);
        $fields = ['codigo','nombre','departamento','provincia','distrito','direccion','hectareas','responsable','telefono','notas'];
        $data = []; foreach ($fields as $f) $data[$f] = trim($_POST[$f] ?? '') ?: null;
        if ($id) {
            $sets = implode(',', array_map(fn($f)=>"$f=:$f", $fields));
            $db->prepare("UPDATE gv_fundos SET $sets WHERE id=:id")->execute(array_merge($data,['id'=>$id]));
        } else {
            $cols = implode(',', $fields); $pls = implode(',', array_map(fn($f)=>":$f", $fields));
            $db->prepare("INSERT INTO gv_fundos ($cols) VALUES ($pls)")->execute($data);
        }
        $msg = 'ok'; $sub = 'fundos'; $action = 'list';
    }

    // Guardar banco semen
    if ($pa === 'save_semen') {
        $fields = ['codigo_pajilla','toro_nombre','raza','procedencia','fecha_ingreso','cantidad','tanque','temperatura','ubicacion_fisica','stock_minimo','fecha_vencimiento','costo_unitario','observaciones'];
        $data = []; foreach ($fields as $f) $data[$f] = trim($_POST[$f] ?? '') ?: null;
        $data['toro_id'] = (int)($_POST['toro_id'] ?? 0) ?: null;
        $cols = implode(',', array_merge($fields,['toro_id']));
        $pls  = implode(',', array_map(fn($f)=>":$f", array_merge($fields,['toro_id'])));
        $db->prepare("INSERT INTO gv_banco_semen ($cols) VALUES ($pls)")->execute($data);
        $msg = 'ok'; $sub = 'banco_semen'; $action = 'list';
    }
}

// ── Datos generales ────────────────────────────────────────────
$fundos   = $db->query("SELECT * FROM gv_fundos WHERE activo=1 ORDER BY nombre")->fetchAll();
$lotes    = $db->query("SELECT l.*,f.nombre as fundo FROM gv_lotes l JOIN gv_fundos f ON f.id=l.fundo_id WHERE l.activo=1 ORDER BY l.nombre")->fetchAll();
$animales = $db->query("SELECT a.*,f.nombre as fundo FROM gv_animales a LEFT JOIN gv_fundos f ON f.id=a.fundo_id WHERE a.activo=1 ORDER BY a.numero_arete")->fetchAll();
$toros    = $db->query("SELECT * FROM gv_toros WHERE activo=1 ORDER BY nombre")->fetchAll();
$vets     = $db->query("SELECT id,nombre FROM usuarios WHERE rol IN ('veterinario','admin') AND activo=1")->fetchAll();

// Alertas ganado
$alertas_ganado = [];
try {
    $par_prox = (int)$db->query("SELECT COUNT(*) FROM gv_prenez WHERE resultado='prenada' AND fecha_probable_parto BETWEEN CURDATE() AND DATE_ADD(CURDATE(),INTERVAL 15 DAY)")->fetchColumn();
    if ($par_prox > 0) $alertas_ganado[] = ['tipo'=>'warn','msg'=>"$par_prox parto".($par_prox>1?'s':'')." próximo".($par_prox>1?'s':''),'icon'=>'🐄'];
    $ins_pend = (int)$db->query("SELECT COUNT(*) FROM gv_inseminaciones WHERE resultado='pendiente' AND fecha_diagnostico_prenez <= DATE_ADD(CURDATE(),INTERVAL 3 DAY)")->fetchColumn();
    if ($ins_pend > 0) $alertas_ganado[] = ['tipo'=>'info','msg'=>"$ins_pend diagnóstico".($ins_pend>1?'s':'')." preñez pendiente",'icon'=>'🔬'];
} catch(Exception $e) {}

